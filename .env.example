# Copy this file to ".env" and fill in your real values.
# The .env file is git-ignored and must NOT be committed.

# Port the mail server runs on
PORT=5050

# --- SMTP credentials ---
# For Gmail: turn on 2-Step Verification, then create an "App Password"
# (https://myaccount.google.com/apppasswords) and paste it below as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-char-app-password

# Display name shown as the sender
MAIL_FROM_NAME=Niambio

# Where contact-form notifications are sent (defaults to SMTP_USER if omitted)
MAIL_TO=info@niambio.com
